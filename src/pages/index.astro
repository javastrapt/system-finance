---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import siteData from '../data/site.json';

import transactions from '../data/transactions.json';

const sortedTransactions = [...transactions].sort(
(a, b) => new Date(b.postDate) - new Date(a.postDate));

const latestRecord = sortedTransactions.shift();
const latestPostDate = latestRecord.postDate;


const pathname = Astro.url.pathname;
const pagePath = pathname === '/' ? pathname : pathname.replace(/\/+$/, '');
const pages = siteData.find((item) => item.id === 'site')?.pages ?? [];
const currentPage = pages.find(page => page.slug === pagePath);

const apps = pages.filter((page) => page.type === 'webapp')

---

<BaseLayout title='Home'>
  <Hero />

  <div class='container col-12 mt-4'>
    {
      apps.map((app) => (
        <div class='card text-bg-dark'>
              <img src={app.bgimage} alt='finance'>
              <div class='card-img-overlay'>
                <h2 class='card-title fw-bold'>{app.name}</h2>
                <p class='card-text'>{app.desc}</p>
                <p class='card-text'><small>Last Transaction: <strong>{latestPostDate}</strong></small></p>
                <div class='col'>
                <a href={app.slug} type='button' class='btn btn-primary btn-sm'>Launch {app.name}</a>
                </div>
              </div>
            </div>      
            ))
          }
    </div>
  </BaseLayout>
<style>

.container {
  width: 100%;
  display: flex;
  align-items: center;
  justifey-content: space-around;
}

.card {
    width: 800px;
    height: 600px;
  }
  .card img {
    max-height: 600px;
    max-width: 800px;
    background-image-size: cover;
    background-blend-mode: overlay;
    backdrop-filter: blur(30px);
  }
  
  .card-img-overlay {
  background-color: rgba(255, 255, 255, 0.4);
  -webkit-backdrop-filter: blur(20px);
  backdrop-filter: blur:(20px);
  padding: 20px;
  margin: 2rem 4rem;
  font-weight: bold;
  height: 50%;
  width: 80%;
  display: flex;
  align-items: left;
  justify-content: center;
  flex-direction: column;
}
</style>