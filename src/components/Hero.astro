---
import "../styles/global.css";
import siteData from "../data/site.json";

const pathname = Astro.url.pathname;
const pagePath = pathname === "/" ? pathname : pathname.replace(/\/+$/, "");
const pages = siteData.find((item) => item.id === "site")?.pages ?? [];
const currentPage = pages.find((page) => page.slug === pagePath);

if (!currentPage) {
  throw new Error(`No page found for ${pathname}`);
}

const hero = currentPage.hero;
const isFinancePage = currentPage.slug === "/finance";
const today = new Date().toISOString().split("T")[0];
---

<div class="col-12 bg-dark text-secondary px-4 py-5">
  <div class="hero container py-5">
    <h1 class="display-5 fw-bold text-white mb-2 hero-title">{hero.title}</h1>
    {hero.subtitle && <p class="hero-subtitle fs-5 mb-5">{hero.subtitle}</p>}

    {
      isFinancePage && (
        <div class="d-flex flex-wrap gap-3 align-items-center">
          <button
            type="button"
            class="btn btn-outline-info btn-lg px-4 fw-bold"
            data-bs-toggle="modal"
            data-bs-target="#addRecord"
            id="btn-add-record"
          >
            Add Record
          </button>
          <button
            type="button"
            class="btn btn-outline-light btn-lg px-4"
            data-bs-toggle="modal"
            data-bs-target="#viewSummary"
            id="btn-view-summary"
          >
            View Summary
          </button>
        </div>
      )
    }
  </div>
</div>

{
  isFinancePage && (
    <>
      <div class="modal fade" id="addRecord" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
          <div class="modal-content rounded-4 shadow">
            <div class="modal-header border-bottom-0">
              <h1 class="modal-title display-5 fw-thin">Add Record</h1>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body py-0">
              <form id="transForm" method="POST">
                <div class="row mb-2">
                  <div class="col floating-form">
                    <label for="type" class="form-label">Transaction Type</label>
                    <select id="type" name="type" class="form-control" required>
                      <option disabled>Type Select...</option>
                    </select>
                  </div>

                  <div class="col form-floating">
                    <input type="text" id="desc" name="desc" class="form-control" placeholder="Description" required />
                    <label for="desc" class="form-label">Description</label>
                  </div>
                </div>

                <div class="row mb-2">
                  <div class="col">
                    <label for="postDate" class="form-label">Post Date</label>
                    <input type="date" id="postDate" name="postDate" class="form-control" value={today} />
                  </div>
                  <div class="col form-floating">
                    <input type="number" id="amount" name="amount" class="form-control" step="0.01" required />
                    <label for="amount" class="form-label">Amount</label>
                  </div>
                </div>

                <div class="row mb-2">
                  <div class="col">
                    <label for="service" class="form-label">Service Used</label>
                    <select id="service" name="service" class="form-select" required>
                      <option disabled>Service Select...</option>
                    </select>
                  </div>
                </div>
              </form>
            </div>

            <div class="modal-footer flex-column align-items-stretch w-100 gap-2 pb-3 border-top-0">
              <button type="submit" class="btn btn-lg btn-primary" form="transForm">Submit</button>
              <button type="button" class="btn btn-lg btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
          </div>
        </div>
      </div>

      <div class="modal fade" id="viewSummary" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
          <div class="modal-content rounded-4 shadow">
            <div class="modal-header border-bottom-0">
              <h1 class="modal-title fs-5">View Summary</h1>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body py-0">
              <p class="mb-3">Use the finance dashboard below to review totals and recent transactions.</p>
            </div>
            <div class="modal-footer flex-column align-items-stretch w-100 gap-2 pb-3 border-top-0">
              <button type="button" class="btn btn-lg btn-primary" data-bs-dismiss="modal">Close Summary</button>
              <button type="button" class="btn btn-lg btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
          </div>
        </div>
      </div>
    </>
  )
}

<script>
  const types = ["Charge", "Payment"];
  const services = ["Zelle", "Paypal", "Venmo", "Chime", "CashApp", "Check", "Money Order", "Cash"];

  const prefillPayment = {
    type: "Payment",
    desc: "Payment Received",
    postDate: "",
    amount: "",
    service: "Zelle",
  };

  const prefillCharge = {
    type: "Charge",
    desc: "",
    postDate: "",
    amount: "",
    service: "Zelle",
  };

  const transForm = document.getElementById("transForm");
  const typeSelect = document.getElementById("type");
  const descEl = document.getElementById("desc");
  const serviceSelect = document.getElementById("service");
  const postDate = document.getElementById("postDate");

  if (transForm && typeSelect && descEl && serviceSelect && postDate) {
    document.addEventListener("DOMContentLoaded", () => {
      populateSelects();
      typeSelect.value = prefillPayment.type;
      serviceSelect.value = prefillPayment.service.toLowerCase();
      loadPaymentPrefill();
    });

    typeSelect.addEventListener("change", () => {
      if (typeSelect.value === "Charge") {
        loadChargePrefill();
        return;
      }

      loadPaymentPrefill();
    });

    transForm.addEventListener("submit", async (event) => {
      await handleSubmit(event);
    });
  }

  function populateSelects() {
    typeSelect.innerHTML = '<option disabled>Type Select...</option>';
    serviceSelect.innerHTML = '<option disabled>Service Select...</option>';

    types.forEach((type) => {
      const option = document.createElement("option");
      option.value = type;
      option.textContent = type;
      typeSelect.appendChild(option);
    });

    services.forEach((service) => {
      const option = document.createElement("option");
      option.value = service.toLowerCase();
      option.textContent = service;
      serviceSelect.appendChild(option);
    });
  }

  async function handleSubmit(event) {
    event.preventDefault();

    const formData = new FormData(transForm);
    const data = Object.fromEntries(formData.entries());

    try {
      const response = await fetch("http://localhost:3000/api/transactions", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (!response.ok) {
        throw new Error(`Request failed with status ${response.status}`);
      }

      transForm.reset();
      typeSelect.value = prefillPayment.type;
      serviceSelect.value = prefillPayment.service.toLowerCase();
      loadPaymentPrefill();
    } catch (error) {
      console.error(error);
    }
  }

  function loadPaymentPrefill() {
    Object.entries(prefillPayment).forEach(([name, value]) => {
      const field = document.querySelector(`[name="${name}"]`);
      if (field) {
        field.value = value;
      }
    });

    postDate.value = new Date().toISOString().split("T")[0];
    descEl.focus();
  }

  function loadChargePrefill() {
    const date = new Date();
    const month = date.toLocaleString("default", { month: "long" });
    const year = date.getFullYear();

    prefillCharge.desc = `${month} ${year} Rent`;

    Object.entries(prefillCharge).forEach(([name, value]) => {
      const field = document.querySelector(`[name="${name}"]`);
      if (field) {
        field.value = value;
      }
    });

    postDate.value = new Date().toISOString().split("T")[0];
  }
</script>
