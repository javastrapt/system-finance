---
import siteData from '../data/site.json';

const site = siteData.find((item) => item.id === 'site');
const pages = site.pages;
---

<nav class="navbar navbar-expand-lg bg-dark navbar-dark">
  <div class="container">
    <a class="navbar-brand" href="/">
      <img src='https://www.tinyurl.com/systemflo-white' alt='systemflo-logo'>
    </a>

    <div class="collapse navbar-collapse">
      <ul class="navbar-nav ms-auto">
        {pages.map(page => (
          <li class="nav-item">
            <a class="nav-link" href={page.slug}>
              {page.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</nav>
<style>
  .navbar-brand img {
    max-height: 70px;
    width: auto;
  }

li .nav-item {
    text-decoration: none;
    transition: text-decoration .5s ease-in-out;
  }

  li .nav-item:hover {
    text-decoration: underline;
  }
</style>